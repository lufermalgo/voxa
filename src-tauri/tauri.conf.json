{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "voxa",
  "version": "1.0.0",
  "identifier": "com.lufermalgo.voxa",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Voxa",
        "width": 300,
        "height": 100,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "fullscreen": false
      },
      {
        "label": "settings",
        "title": "Voxa Settings",
        "width": 1200,
        "height": 900,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/tray-icon.png"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "entitlements": null,
      "infoPlist": "Info.plist"
    }
  }
}
